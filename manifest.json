{
  "manifest_version": 3,
  "name": "AI Chat Keymap",
  "description": "ChatGPT, Claude, GeminiでのEnterキー動作を変更: Enter/Shift+Enter→改行、Cmd/Ctrl+Enter→送信",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
